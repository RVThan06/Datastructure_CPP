{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_MAKE_PROGRAM": "C:/msys64/ucrt64/bin/mingw32-make.exe"
            }
        },
        {
            "name": "linux-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "win-dev",
            "displayName": "Windows Dev (Debug)",
            "description": "Windows Debug build with strict warnings",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "DATASTRUCTS_BUILD_TESTS": "ON",
                "DATASTRUCTS_BUILD_EXAMPLES": "ON",
                "DATASTRUCTS_BUILD_SANDBOX": "ON"
            }
        },
        {
            "name": "linux-dev",
            "displayName": "Linux Dev (Debug)",
            "description": "Linux Debug build with strict warnings",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "DATASTRUCTS_BUILD_TESTS": "ON",
                "DATASTRUCTS_BUILD_EXAMPLES": "ON",
                "DATASTRUCTS_BUILD_SANDBOX": "ON"
            }
        },
        {
            "name": "win-release",
            "displayName": "Windows Release",
            "description": "Windows Optimized release build",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "DATASTRUCTS_BUILD_TESTS": "OFF",
                "DATASTRUCTS_BUILD_EXAMPLES": "ON",
                "DATASTRUCTS_BUILD_SANDBOX": "ON"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "description": "Linux Optimized release build",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "DATASTRUCTS_BUILD_TESTS": "OFF",
                "DATASTRUCTS_BUILD_EXAMPLES": "ON",
                "DATASTRUCTS_BUILD_SANDBOX": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "win-dev",
            "configurePreset": "win-dev"
        },
        {
            "name": "linux-dev",
            "configurePreset": "linux-dev"
        },
        {
            "name": "win-release",
            "configurePreset": "win-release"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        }
    ]
}
